{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(python3 -m pytest *)",
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Read(./app/**)",
      "Read(./docs/**)",
      "Read(./data/**)",
      "Read(./mcp/**)",
      "Read(./infra/**)",
      "Read(./tests/**)",
      "Read(./scripts/**)",
      "Read(./.claude/**)",
      "Read(./CLAUDE.md)",
      "Read(./README.md)",
      "Read(./requirements.txt)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.claude/settings.local.json)",
      "Read(./secrets/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 infra/hooks/pre_tool_use.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 infra/hooks/post_tool_use.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 infra/hooks/session_start.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 infra/hooks/completion.py"
          }
        ]
      }
    ]
  }
}
